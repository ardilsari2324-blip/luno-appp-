# Luno — Ortam değişkenleri
# Bu dosyayı .env olarak kopyalayıp değerleri doldurun.

DATABASE_URL="file:./dev.db"
AUTH_SECRET="güçlü-32-karakterlik-gizli-anahtar-üretin"
NEXTAUTH_URL="http://localhost:3001"

# Sentry (Error monitoring) — production için önerilir
# NEXT_PUBLIC_SENTRY_DSN="https://xxxx@o0.ingest.sentry.io/0"
# SENTRY_DSN="https://xxxx@o0.ingest.sentry.io/0" # server/edge için opsiyonel (yoksa NEXT_PUBLIC_SENTRY_DSN kullanılır)
# SENTRY_AUTH_TOKEN="sntrys_..."  # source map upload için (CI/CD)
# SENTRY_ORG="your-org"
# SENTRY_PROJECT="your-project"
# NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE="0.1"
# NEXT_PUBLIC_SENTRY_REPLAYS_SESSION_SAMPLE_RATE="0"
# NEXT_PUBLIC_SENTRY_REPLAYS_ON_ERROR_SAMPLE_RATE="0"
# SENTRY_TRACES_SAMPLE_RATE="0.1"

# E-posta (Resend) — OTP ve bildirimler için
RESEND_API_KEY="re_xxxxx"
# RESEND_FROM_EMAIL="Luno <noreply@yourdomain.com>"

# Admin paneli — Virgülle ayrılmış kullanıcı ID'leri
# ADMIN_USER_ID="cuid1"
# ADMIN_USER_IDS="cuid1,cuid2"

# Medya yükleme (Vercel Blob) — production için
# BLOB_READ_WRITE_TOKEN="vercel_blob_xxxxx"

# SMS OTP (Twilio) — telefon ile giriş için
# TWILIO_ACCOUNT_SID="ACxxxx"
# TWILIO_AUTH_TOKEN="xxxx"
# TWILIO_PHONE_NUMBER="+1234567890"

# Rate limit (Upstash Redis) — production için önerilir
# UPSTASH_REDIS_REST_URL="https://xxx.upstash.io"
# UPSTASH_REDIS_REST_TOKEN="xxx"

# Postgres (opsiyonel) — docker-compose ile local
# DATABASE_URL="postgresql://luno:luno@localhost:5432/luno?schema=public"
